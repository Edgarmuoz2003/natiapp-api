{
  "name": "natiapp-api",
  "version": "1.0.0",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "dev": "npm run db:migrate && nodemon --exec \"node --env-file=.env\" index.js",
    "start": "npm run db:migrate && node --env-file=.env index.js",
    "db:migrate": "node --env-file=.env ./node_modules/sequelize-cli/lib/sequelize db:migrate",
    "db:migrate:undo": "node --env-file=.env ./node_modules/sequelize-cli/lib/sequelize db:migrate:undo",
    "db:create:migration": "node --env-file=.env ./node_modules/sequelize-cli/lib/sequelize migration:generate --name",
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --runInBand"
  },
  "keywords": [],
  "author": "Edgar munoz",
  "license": "ISC",
  "description": "backend for natiapp natillera digital",
  "dependencies": {
    "@apollo/server": "^5.4.0",
    "@as-integrations/express5": "^1.1.2",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "graphql": "^16.13.0",
    "graphql-tag": "^2.12.6",
    "pg": "^8.19.0",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.7"
  },
  "devDependencies": {
    "jest": "^30.2.0",
    "nodemon": "^3.1.14",
    "sequelize-cli": "^6.6.5"
  }
}
